# =========================================================================
# Oasys School Dashboard — contoh environment variables
# Salin file ini menjadi `.env` lalu sesuaikan nilainya.
# JANGAN commit file `.env` yang berisi nilai asli (sudah di-.gitignore).
# =========================================================================

# --- API ---
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_API_VERSION=v1

# --- Aplikasi ---
# Dashboard web SELALU 'web' (dikirim di setiap login/refresh — NFR-SEC.5).
VITE_APP_PLATFORM=web
VITE_APP_NAME="Oasys School Dashboard"
VITE_APP_VERSION=0.1.0

# --- Token & sesi ---
# Access token disimpan di memori; key ini hanya untuk membersihkan sisa lama.
VITE_TOKEN_STORAGE_KEY=oasys_access_token
VITE_REFRESH_TOKEN_STORAGE_KEY=oasys_refresh_token
# Buffer (ms) untuk refresh proaktif sebelum access token benar-benar habis.
VITE_TOKEN_EXPIRY_BUFFER_MS=60000

# --- Pagination ---
VITE_DEFAULT_PAGE_SIZE=20
VITE_MAX_PAGE_SIZE=100

# --- Feature flags (build-time) ---
VITE_ENABLE_MOCK_API=false
VITE_ENABLE_PARENT_REGISTRATION_PAGE=true
VITE_ENABLE_ANALYTICS=false

# --- Observability (opsional) ---
VITE_SENTRY_DSN=
